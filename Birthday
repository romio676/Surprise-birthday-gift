#!/usr/bin/env bash
set -e

APP="eternal-birthday"
echo "Creating Next.js app..."
npx create-next-app@latest "$APP" --typescript --tailwind --app --eslint --no-src-dir --import-alias "@/*" --yes

cd "$APP"

echo "Installing dependencies..."
npm install @supabase/supabase-js @supabase/ssr framer-motion canvas-confetti lucide-react
npm install -D @types/canvas-confetti

echo "Writing files..."

mkdir -p lib/supabase app/api/unlock "app/s/[slug]"

# ---------- .env.local ----------
cat > .env.local <<'EOF'
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
EOF

# ---------- schema.sql ----------
cat > schema.sql <<'EOF'
create table profiles (
  id uuid primary key references auth.users on delete cascade,
  email text,
  display_name text,
  plan text default 'free' check (plan in ('free','premium')),
  created_at timestamptz default now()
);

create table surprise_pages (
  id uuid primary key default gen_random_uuid(),
  creator_id uuid references auth.users on delete cascade,
  slug text unique not null,
  birthday_person_name text not null,
  birthday_date date,
  relationship text,
  cover_title text,
  special_message text,
  password_hash text,
  visibility text default 'private' check (visibility in ('private','password','public')),
  background_music_url text,
  created_at timestamptz default now()
);

create table media (
  id uuid primary key default gen_random_uuid(),
  page_id uuid references surprise_pages on delete cascade,
  type text not null check (type in ('photo','video','voice')),
  storage_path text not null,
  caption text,
  sort_order int default 0,
  created_at timestamptz default now()
);

create table guestbook_messages (
  id uuid primary key default gen_random_uuid(),
  page_id uuid references surprise_pages on delete cascade,
  author_name text not null,
  message text not null,
  emoji text,
  created_at timestamptz default now()
);

create table analytics (
  id uuid primary key default gen_random_uuid(),
  page_id uuid references surprise_pages on delete cascade,
  event text not null,
  created_at timestamptz default now()
);

alter table profiles enable row level security;
alter table surprise_pages enable row level security;
alter table media enable row level security;
alter table guestbook_messages enable row level security;

create policy "own profile" on profiles for all using (auth.uid() = id);
create policy "creator manages pages" on surprise_pages for all using (auth.uid() = creator_id);
create policy "read public pages" on surprise_pages for select using (visibility = 'public');
create policy "creator reads media" on media for all using (
  exists (select 1 from surprise_pages p where p.id = media.page_id and p.creator_id = auth.uid())
);
create policy "anyone reads guestbook" on guestbook_messages for select using (true);
create policy "anyone signs guestbook" on guestbook_messages for insert with check (true);
EOF

# ---------- lib/supabase/server.ts ----------
cat > lib/supabase/server.ts <<'EOF'
import { createServerClient } from '@supabase/ssr'
import { cookies } from 'next/headers'

export async function createClient() {
  const cookieStore = await cookies()
  return createServerClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
    {
      cookies: {
        getAll: () => cookieStore.getAll(),
        setAll: (toSet) => {
          try {
            toSet.forEach(({ name, value, options }) =>
              cookieStore.set(name, value, options))
          } catch {}
        },
      },
    }
  )
}
EOF

